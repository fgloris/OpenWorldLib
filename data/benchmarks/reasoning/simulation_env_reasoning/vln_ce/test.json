{"episodes": [{"episode_id": 1, "trajectory_id": 5732, "scene_id": "mp3d/5ZKStnWn8Zo/5ZKStnWn8Zo.glb", "start_position": [6.307720184326172, 0.12089109420776367, 0.18507300317287445], "start_rotation": [-0.0, 0.9659258262890683, -0.0, -0.25881904510252063], "instruction": {"instruction_text": "Go down the staircase, then take a sharp left and walk straight. Wait at the entrance to the bedroom. ", "instruction_tokens": [1067, 780, 2389, 2220, 2394, 2352, 73, 2091, 1360, 119, 2584, 2288, 15, 2579, 178, 2389, 867, 2438, 2389, 273, 15]}}, {"episode_id": 2, "trajectory_id": 5732, "scene_id": "mp3d/5ZKStnWn8Zo/5ZKStnWn8Zo.glb", "start_position": [6.307720184326172, 0.12089109420776367, 0.18507300317287445], "start_rotation": [-0.0, 0.9659258262890683, -0.0, -0.25881904510252063], "instruction": {"instruction_text": "Go down the stairs. Turn left and go straight into the room. Wait at the entrance. ", "instruction_tokens": [1067, 780, 2389, 2222, 15, 2494, 1360, 119, 1067, 2288, 1264, 2389, 1994, 15, 2579, 178, 2389, 867, 15]}}, {"episode_id": 3, "trajectory_id": 5732, "scene_id": "mp3d/5ZKStnWn8Zo/5ZKStnWn8Zo.glb", "start_position": [6.307720184326172, 0.12089109420776367, 0.18507300317287445], "start_rotation": [-0.0, 0.9659258262890683, -0.0, -0.25881904510252063], "instruction": {"instruction_text": "Go downstairs and wait to the left, in the bedroom. ", "instruction_tokens": [1067, 782, 119, 2579, 2438, 2389, 1360, 1237, 2389, 273, 15]}}, {"episode_id": 4, "trajectory_id": 5808, "scene_id": "mp3d/5ZKStnWn8Zo/5ZKStnWn8Zo.glb", "start_position": [-0.3505859971046448, 0.12089109420776367, 2.788520097732544], "start_rotation": [-0.0, 0.49999999999999994, -0.0, -0.8660254037844387], "instruction": {"instruction_text": "Walk down the hallway along the banister railing on the upper floor of the home. Walk through the open door next to the staircase. Walk into the room, which has a couch and chairs around a coffee table. ", "instruction_tokens": [2584, 780, 2389, 1126, 108, 2389, 211, 1910, 1613, 2389, 2531, 959, 1605, 2389, 1198, 15, 2584, 2418, 2389, 1625, 757, 1576, 2438, 2389, 2220, 15, 2584, 1264, 2389, 1994, 2634, 1156, 73, 593, 119, 458, 159, 73, 534, 2342, 15]}}, {"episode_id": 5, "trajectory_id": 5808, "scene_id": "mp3d/5ZKStnWn8Zo/5ZKStnWn8Zo.glb", "start_position": [-0.3505859971046448, 0.12089109420776367, 2.788520097732544], "start_rotation": [-0.0, 0.49999999999999994, -0.0, -0.8660254037844387], "instruction": {"instruction_text": "Go straight until you pass two lamps in the hallway. Turn right and go into the room. Wait there. ", "instruction_tokens": [1067, 2288, 2524, 2703, 1721, 2509, 1326, 1237, 2389, 1126, 15, 2494, 1968, 119, 1067, 1264, 2389, 1994, 15, 2579, 2395, 15]}}, {"episode_id": 6, "trajectory_id": 5808, "scene_id": "mp3d/5ZKStnWn8Zo/5ZKStnWn8Zo.glb", "start_position": [-0.3505859971046448, 0.12089109420776367, 2.788520097732544], "start_rotation": [-0.0, 0.49999999999999994, -0.0, -0.8660254037844387], "instruction": {"instruction_text": "Walk parallel to the stairs, keeping the railing on your left.  Enter the open bedroom at the top of the staircase and stop once you have stepped inside. ", "instruction_tokens": [2584, 1711, 2438, 2389, 2222, 1296, 2389, 1910, 1613, 2706, 1360, 15, 860, 2389, 1625, 273, 178, 2389, 2444, 1605, 2389, 2220, 119, 2278, 1615, 2703, 1159, 2262, 1249, 15]}}, {"episode_id": 7, "trajectory_id": 4095, "scene_id": "mp3d/5ZKStnWn8Zo/5ZKStnWn8Zo.glb", "start_position": [7.161220073699951, 0.12089109420776367, 1.1579400300979614], "start_rotation": [-0.0, 0.7071067811865475, 0.0, 0.7071067811865476], "instruction": {"instruction_text": "Turn right toward the landing of the stairs and proceed down them.  Stop in the doorway to the left of the lower landing of the stairs, just before you enter the kitchen. ", "instruction_tokens": [2494, 1968, 2451, 2389, 1329, 1605, 2389, 2222, 119, 1878, 780, 2393, 15, 2278, 1237, 2389, 766, 2438, 2389, 1360, 1605, 2389, 1435, 1329, 1605, 2389, 2222, 